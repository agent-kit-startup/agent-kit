#!/bin/sh
# Block direct pushes to the production branch (main/master) on any remote.
# main is promoted only via `git prod` (merge from staging). Feature/staging pushes are fine.
# Install: cp git-hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#
# Git feeds pre-push lines on stdin: <local ref> <local sha> <remote ref> <remote sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      echo "BLOCKED: direct push to '$remote_ref'." >&2
      echo "Promote via the staging -> prod flow ('git prod'), not a direct push." >&2
      echo "Override once (only if you really must): git push --no-verify" >&2
      exit 1
      ;;
  esac
done
exit 0
