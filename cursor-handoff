#!/usr/bin/env sh
# cursor-handoff - Context Memory System CLI
# Commands: new, update, status, handoff, archive, resume, list-projects
# Usage: cursor-handoff <command> [task-id|project]

set -e

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
CONTEXT="$REPO_ROOT/.cursor/context"
CURRENT="$CONTEXT/current"
ARCHIVE="$CONTEXT/archive"
TEMPLATES="$CONTEXT/templates"
HANDOFF_FILE="$REPO_ROOT/.cursor/HANDOFF.md"
PACK_TEMPLATE="$TEMPLATES/context-pack.md"
HANDOFF_TEMPLATE="$TEMPLATES/handoff.md"

now_iso() {
  date '+%Y-%m-%d %H:%M'
}
now_ym() {
  date '+%Y-%m'
}

get_current_task_id() {
  for f in "$CURRENT"/*.md; do
    [ -f "$f" ] || continue
    basename "$f" .md
    return 0
  done
  return 1
}

# Detect project folder for handoff: .cursor/HANDOFF.md, active Context Pack, or ask
detect_project() {
  DETECTED_PROJECT=""
  if [ -f "$HANDOFF_FILE" ]; then
    DETECTED_PROJECT=$(grep -m1 '^\-\s*\*\*Project:\*\*' "$HANDOFF_FILE" 2>/dev/null | sed 's/^-\s*\*\*Project:\*\*\s*//' | sed 's/\s*$//')
    [ -n "$DETECTED_PROJECT" ] || DETECTED_PROJECT=$(grep -m1 '^\-\s*\*\*Projeto:\*\*' "$HANDOFF_FILE" 2>/dev/null | sed 's/^-\s*\*\*Projeto:\*\*\s*//' | sed 's/\s*$//')
  fi
  if [ -z "$DETECTED_PROJECT" ]; then
    task_id=$(get_current_task_id) || true
    if [ -n "$task_id" ] && [ -f "$CURRENT/${task_id}.md" ]; then
      DETECTED_PROJECT=$(grep -m1 '^\*\*Project:\*\*' "$CURRENT/${task_id}.md" 2>/dev/null | sed 's/^\*\*Project:\*\*\s*//' | sed 's/\s*$//')
      [ -n "$DETECTED_PROJECT" ] || DETECTED_PROJECT=$(grep -m1 '^\*\*Projeto:\*\*' "$CURRENT/${task_id}.md" 2>/dev/null | sed 's/^\*\*Projeto:\*\*\s*//' | sed 's/\s*$//')
    fi
  fi
  if [ -z "$DETECTED_PROJECT" ]; then
    echo ""
    printf "Enter project folder (e.g: agent_incidents): "
    read -r DETECTED_PROJECT
  fi
}

cmd_new() {
  task_id="$1"
  if [ -z "$task_id" ]; then
    task_id="task-$(date +%Y%m%d%H%M)"
  fi
  if [ ! -f "$PACK_TEMPLATE" ]; then
    echo "Template not found: $PACK_TEMPLATE"
    exit 2
  fi
  dest="$CURRENT/${task_id}.md"
  mkdir -p "$CURRENT"
  now=$(now_iso)
  sed -e "s/\[TASK-ID\]/${task_id}/g" \
      -e "s/\[YYYY-MM-DD HH:MM\]/${now}/g" \
      -e "s/\[draft|active|review|done|archived\]/active/" \
      "$PACK_TEMPLATE" > "$dest"
  echo "Context Pack created: $dest"
  echo "Edit the file to fill in state and constraints."
}

cmd_update() {
  task_id=$(get_current_task_id) || true
  if [ -z "$task_id" ]; then
    echo "No active task in $CURRENT"
    echo "Use: cursor-handoff new [task-id]"
    exit 1
  fi
  dest="$CURRENT/${task_id}.md"
  now=$(now_iso)
  if [ -f "$dest" ]; then
    if sed -i.bak "s/\*\*Last updated:\*\* .*/\*\*Last updated:\*\* ${now}/" "$dest" 2>/dev/null; then
      rm -f "${dest}.bak"
    elif sed -i.bak "s/\*\*Última atualização:\*\* .*/\*\*Last updated:\*\* ${now}/" "$dest" 2>/dev/null; then
      rm -f "${dest}.bak"
    fi
    echo "Context Pack updated: $dest (Last updated: ${now})"
  else
    echo "File not found: $dest"
    exit 1
  fi
}

cmd_status() {
  PLANS_DIR="$REPO_ROOT/.cursor/plans"
  
  # 1. Active Context Pack
  task_id=$(get_current_task_id) || true
  if [ -n "$task_id" ]; then
    echo "Active Context Pack: $task_id"
    echo "  File: $CURRENT/${task_id}.md"
    echo ""
  fi
  
  # 2. Cursor plans (.plan.md files)
  plan_count=0
  if [ -d "$PLANS_DIR" ]; then
    for f in "$PLANS_DIR"/*.plan.md; do
      [ -f "$f" ] || continue
      plan_count=$((plan_count + 1))
    done
  fi
  
  if [ "$plan_count" -gt 0 ]; then
    echo "Active plans ($plan_count):"
    for f in "$PLANS_DIR"/*.plan.md; do
      [ -f "$f" ] || continue
      name=$(basename "$f" .plan.md)
      # Extract plan title (first line starting with #)
      title=$(grep -m1 '^# ' "$f" 2>/dev/null | sed 's/^# //' || echo "$name")
      echo "  - $name"
      echo "    $title"
    done
    echo ""
  fi
  
  # 3. Message if nothing active
  if [ -z "$task_id" ] && [ "$plan_count" -eq 0 ]; then
    echo "No active task or plan."
    echo "Use: cursor-handoff new [task-id]"
    echo ""
  fi
  
  # 4. Handoffs by project
  echo "Handoffs by project:"
  project_handoff_count=0
  for d in "$REPO_ROOT"/*/; do
    [ -d "$d" ] || continue
    [ -f "${d}HANDOFF.md" ] || continue
    proj=$(basename "$d")
    project_handoff_count=$((project_handoff_count + 1))
    echo "  - $proj/HANDOFF.md"
  done 2>/dev/null
  if [ "$project_handoff_count" -eq 0 ]; then
    echo "  (none)"
  fi
  echo ""

  # 5. Archived
  echo "Archived (recent):"
  archived_count=0
  for dir in "$ARCHIVE"/20*; do
    [ -d "$dir" ] || continue
    for f in "$dir"/*.md; do
      [ -f "$f" ] || continue
      archived_count=$((archived_count + 1))
      echo "  - $(basename "$dir")/$(basename "$f" .md)"
    done
  done 2>/dev/null | tail -10
  
  if [ "$archived_count" -eq 0 ]; then
    echo "  (none)"
  fi
}

cmd_handoff() {
  project_arg="$1"
  task_id=$(get_current_task_id) || true
  if [ -z "$task_id" ]; then
    echo "No active task. Use: cursor-handoff new [task-id]"
    exit 1
  fi
  pack="$CURRENT/${task_id}.md"
  if [ -n "$project_arg" ]; then
    project="$project_arg"
  else
    detect_project
    project="$DETECTED_PROJECT"
  fi
  [ -n "$project" ] || { echo "Project not specified."; exit 1; }
  project_handoff="$REPO_ROOT/$project/HANDOFF.md"
  mkdir -p "$(dirname "$project_handoff")" "$(dirname "$HANDOFF_FILE")"
  now=$(now_iso)
  {
    echo "# Handoff - $task_id"
    echo ""
    echo "- **Project:** $project"
    echo "- **Last updated:** $now"
    echo "- **Context Pack:** $pack"
    echo ""
    echo "## State (Context Pack summary)"
    echo ""
    if grep -q '## Current State' "$pack" 2>/dev/null; then
      sed -n '/## Current State/,/## /p' "$pack" 2>/dev/null | head -20
    else
      sed -n '/## Estado Atual/,/## /p' "$pack" 2>/dev/null | head -20
    fi
    echo ""
    echo "## Instruction for Next Agent"
    echo ""
    sed -n '/## Handoff Notes/,/^## /p' "$pack" 2>/dev/null | head -15
  } > "$project_handoff"
  cp "$project_handoff" "$HANDOFF_FILE"
  echo "HANDOFF.md updated: $project_handoff (project)"
  echo "HANDOFF.md mirror: $HANDOFF_FILE"
  echo "Next agent: read .cursor/HANDOFF.md or <project>/HANDOFF.md and resume from the instruction above."
}

cmd_list_projects() {
  echo "Projects with HANDOFF.md:"
  count=0
  for d in "$REPO_ROOT"/*/; do
    [ -d "$d" ] || continue
    [ -f "${d}HANDOFF.md" ] || continue
    proj=$(basename "$d")
    count=$((count + 1))
    echo "  $proj"
  done 2>/dev/null
  if [ "$count" -eq 0 ]; then
    echo "  (none)"
  fi
}

cmd_archive() {
  task_id=$(get_current_task_id) || true
  if [ -z "$task_id" ]; then
    echo "No active task to archive."
    exit 1
  fi
  cmd_handoff ""
  ym=$(now_ym)
  dest_dir="$ARCHIVE/$ym"
  dest="$dest_dir/${task_id}.md"
  mkdir -p "$dest_dir"
  mv "$CURRENT/${task_id}.md" "$dest"
  echo "Task archived: $dest"
}

list_archived_tasks() {
  i=0
  for dir in "$ARCHIVE"/20*; do
    [ -d "$dir" ] || continue
    for f in "$dir"/*.md; do
      [ -f "$f" ] || continue
      i=$((i + 1))
      task_name=$(basename "$f" .md)
      month=$(basename "$dir")
      echo "$i) $task_name ($month)"
      eval "TASK_$i=\"$f\""
      eval "TASKID_$i=\"$task_name\""
    done
  done 2>/dev/null
  echo "$i"
}

cmd_resume() {
  task_id="$1"
  
  # Interactive mode: if no task-id passed, list and ask
  if [ -z "$task_id" ]; then
    echo "Archived tasks:"
    echo ""
    
    # Collect tasks in arrays
    count=0
    for dir in "$ARCHIVE"/20*; do
      [ -d "$dir" ] || continue
      for f in "$dir"/*.md; do
        [ -f "$f" ] || continue
        count=$((count + 1))
        task_name=$(basename "$f" .md)
        month=$(basename "$dir")
        echo "  $count) $task_name ($month)"
        eval "TASK_PATH_$count=\"$f\""
        eval "TASK_ID_$count=\"$task_name\""
      done
    done 2>/dev/null
    
    if [ "$count" -eq 0 ]; then
      echo "  (no archived tasks)"
      echo ""
      echo "To resume by project: cursor-handoff resume <project-name>"
      echo "  (list-projects shows projects with HANDOFF.md)"
      exit 0
    fi
    
    echo ""
    printf "Which task to resume? (1-%d or 'q' to exit): " "$count"
    read -r choice
    
    if [ "$choice" = "q" ] || [ "$choice" = "Q" ]; then
      echo "Cancelled."
      exit 0
    fi
    
    if ! echo "$choice" | grep -qE '^[0-9]+$' || [ "$choice" -lt 1 ] || [ "$choice" -gt "$count" ]; then
      echo "Invalid option: $choice"
      exit 2
    fi
    
    eval "found=\"\$TASK_PATH_$choice\""
    eval "task_id=\"\$TASK_ID_$choice\""
  else
    # Mode with argument: search by name in archive
    found=""
    for dir in "$ARCHIVE"/20*; do
      [ -d "$dir" ] || continue
      if [ -f "$dir/${task_id}.md" ]; then
        found="$dir/${task_id}.md"
        break
      fi
    done
    # If not found in archive, check if it's a project (folder with HANDOFF.md)
    if [ -z "$found" ] && [ -f "$REPO_ROOT/${task_id}/HANDOFF.md" ]; then
      mkdir -p "$(dirname "$HANDOFF_FILE")"
      cp "$REPO_ROOT/${task_id}/HANDOFF.md" "$HANDOFF_FILE"
      echo "Project handoff loaded: $task_id/HANDOFF.md -> .cursor/HANDOFF.md"
      echo "Next step: open a new conversation and use /continue-plan (or read .cursor/HANDOFF.md)."
      exit 0
    fi
    if [ -z "$found" ]; then
      echo "Task not found in archive: $task_id"
      echo "Tip: list-projects shows projects with HANDOFF; resume <id> resumes archived task or project."
      exit 1
    fi
  fi
  
  mkdir -p "$CURRENT"
  cp "$found" "$CURRENT/${task_id}.md"
  echo "Task resumed: $CURRENT/${task_id}.md (copy of $found)"
}

cmd_list_skills() {
  # List skills from registry. Usage: list [category]
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  if [ "$(basename "$SCRIPT_DIR")" = "agent-kit" ]; then
    AGENT_KIT="$SCRIPT_DIR"
  else
    AGENT_KIT="$SCRIPT_DIR/agent-kit"
  fi
  REGISTRY="$AGENT_KIT/skills-registry.json"
  FILTER_CAT="$1"

  if [ ! -f "$REGISTRY" ]; then
    echo "Registry not found: $REGISTRY"
    echo "Generate with: scripts/build-registry.sh <.cursor/skills-folder> skills-registry.json"
    echo "  (from kit folder, or: agent-kit/scripts/build-registry.sh .cursor/skills agent-kit/skills-registry.json from project root)"
    exit 1
  fi

  # Extract one line per skill (supports minified or pretty-printed JSON)
  list_skill_lines() {
    sed 's/},{"/\n},{"/g' "$REGISTRY" | grep '"path":' | sed 's/^[[:space:]]*//;s/,$//'
  }

  print_skill() {
    line="$1"
    # Accept "key":"value" or "key": "value"
    name=$(echo "$line" | sed -n 's/.*"name": *"\([^"]*\)".*/\1/p')
    path=$(echo "$line" | sed -n 's/.*"path": *"\([^"]*\)".*/\1/p')
    cat=$(echo "$line" | sed -n 's/.*"category": *"\([^"]*\)".*/\1/p')
    desc=$(echo "$line" | sed -n 's/.*"description": *"\([^"]*\)".*/\1/p')
    # Truncate description (POSIX)
    desc_len=$(printf '%s' "$desc" | wc -c | tr -d ' ')
    if [ "$desc_len" -gt 60 ] 2>/dev/null; then
      desc=$(printf '%.57s...' "$desc")
    fi
    printf "  %-20s %-14s %s\n" "$name" "($cat)" "$desc"
  }

  SKILLS_TMP=$(mktemp -t cursor-handoff-skills.XXXXXX) || exit 1
  list_skill_lines > "$SKILLS_TMP"

  # Grep accepts "category":"x" or "category": "x" (with space)
  match_cat() {
    echo "$1" | grep -qE "\"category\": *\"$2\""
  }
  if [ -n "$FILTER_CAT" ]; then
    echo "Skills — category: $FILTER_CAT"
    echo ""
    while read -r line; do
      match_cat "$line" "$FILTER_CAT" && print_skill "$line"
    done < "$SKILLS_TMP"
  else
    echo "Skills (by category)"
    echo ""
    for cat in data docs integrations quality devops creation; do
      need_header=1
      while read -r line; do
        if match_cat "$line" "$cat"; then
          [ "$need_header" = 1 ] && echo "  [$cat]" && need_header=0
          print_skill "$line"
        fi
      done < "$SKILLS_TMP"
      [ "$need_header" = 0 ] && echo ""
    done
    while read -r line; do
      if ! echo "$line" | grep -qE '"category": *"[^"]*"'; then
        echo "  [no category]"
        print_skill "$line"
      fi
    done < "$SKILLS_TMP"
  fi
  rm -f "$SKILLS_TMP"
}

cmd_install() {
  # Profile: minimo | completo | custom. No arg = completo (previous behavior).
  PROFILE="${1:-completo}"
  case "$PROFILE" in
    minimo|minimum) PROFILE=minimo ;;
    completo|full)  PROFILE=completo ;;
    custom)         PROFILE=custom ;;
    *)
      echo "Invalid profile: $PROFILE"
      echo "Use: cursor-handoff install [minimo|completo|custom]"
      echo "  minimo   = handoff + context + git (without rules, skills, agents)"
      echo "  completo = everything (default)"
      echo "  custom   = ask for skill categories"
      exit 2
      ;;
  esac

  # Detect target: if we are in agent-kit/, install in parent directory
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  if [ "$(basename "$SCRIPT_DIR")" = "agent-kit" ]; then
    TARGET="$(dirname "$SCRIPT_DIR")"
    AGENT_KIT="$SCRIPT_DIR"
  else
    TARGET="$SCRIPT_DIR"
    AGENT_KIT="$SCRIPT_DIR/agent-kit"
  fi
  
  CURSOR_DIR="$TARGET/.cursor"
  SRC="$AGENT_KIT/.cursor"
  
  echo "Installing Agent Kit in: $TARGET (profile: $PROFILE)"
  echo ""
  
  # 0. Check Node.js (for hooks)
  if ! command -v node >/dev/null 2>&1; then
    echo "Warning: Node.js not found. JSON/n8n validation hooks need Node.js."
    echo ""
  fi
  
  # 1. Create directory structure
  echo "Creating directory structure..."
  mkdir -p "$CURSOR_DIR/rules"
  mkdir -p "$CURSOR_DIR/skills"
  mkdir -p "$CURSOR_DIR/agents"
  mkdir -p "$CURSOR_DIR/hooks/lib"
  mkdir -p "$CURSOR_DIR/hooks/pre-edit"
  mkdir -p "$CURSOR_DIR/hooks/post-edit"
  mkdir -p "$CURSOR_DIR/hooks/pre-commit"
  mkdir -p "$CURSOR_DIR/hooks/on-task-start"
  mkdir -p "$CURSOR_DIR/hooks/on-task-end"
  mkdir -p "$CURSOR_DIR/context/templates"
  mkdir -p "$CURSOR_DIR/context/current"
  mkdir -p "$CURSOR_DIR/context/archive"
  mkdir -p "$CURSOR_DIR/context/backups"
  mkdir -p "$CURSOR_DIR/context/decisions"
  mkdir -p "$CURSOR_DIR/commands"
  mkdir -p "$CURSOR_DIR/plans"
  
  for dir in current archive backups decisions; do
    touch "$CURSOR_DIR/context/$dir/.gitkeep" 2>/dev/null || true
  done
  touch "$CURSOR_DIR/hooks/on-task-start/.gitkeep" 2>/dev/null || true
  touch "$CURSOR_DIR/hooks/on-task-end/.gitkeep" 2>/dev/null || true
  touch "$CURSOR_DIR/plans/.gitkeep" 2>/dev/null || true
  
  # 2. Copy according to profile
  if [ -d "$SRC" ]; then
    echo "Copying files (profile $PROFILE)..."
    
    # Handoff + context + commands: always (all profiles)
    for f in "$SRC/context/templates"/*.md; do
      [ -f "$f" ] && cp "$f" "$CURSOR_DIR/context/templates/" && echo "  + context/templates/$(basename "$f")"
    done
    for f in "$SRC"/commands/*.md; do
      [ -f "$f" ] && cp "$f" "$CURSOR_DIR/commands/" && echo "  + commands/$(basename "$f")"
    done
    if [ ! -f "$CURSOR_DIR/HANDOFF.md" ]; then
      if [ -f "$AGENT_KIT/HANDOFF.md.example" ]; then
        cp "$AGENT_KIT/HANDOFF.md.example" "$CURSOR_DIR/HANDOFF.md"
        echo "  + HANDOFF.md"
        FIRST_INSTALL=true
      fi
    fi
    
    # Rules, skills, agents, hooks: only completo or custom
    if [ "$PROFILE" = "completo" ] || [ "$PROFILE" = "custom" ]; then
      for f in "$SRC"/rules/*.mdc; do
        [ -f "$f" ] && cp "$f" "$CURSOR_DIR/rules/" && echo "  + rules/$(basename "$f")"
      done
      for f in "$SRC"/agents/*.md; do
        [ -f "$f" ] && cp "$f" "$CURSOR_DIR/agents/" && echo "  + agents/$(basename "$f")"
      done
      for f in "$SRC/hooks/lib"/*.js; do
        [ -f "$f" ] && cp "$f" "$CURSOR_DIR/hooks/lib/" && echo "  + hooks/lib/$(basename "$f")"
      done
      for f in "$SRC/hooks/pre-edit"/*.sh; do
        [ -f "$f" ] && cp "$f" "$CURSOR_DIR/hooks/pre-edit/" && chmod +x "$CURSOR_DIR/hooks/pre-edit/$(basename "$f")" && echo "  + hooks/pre-edit/$(basename "$f")"
      done
      for f in "$SRC/hooks/post-edit"/*.sh; do
        [ -f "$f" ] && cp "$f" "$CURSOR_DIR/hooks/post-edit/" && chmod +x "$CURSOR_DIR/hooks/post-edit/$(basename "$f")" && echo "  + hooks/post-edit/$(basename "$f")"
      done
      for f in "$SRC/hooks/pre-commit"/*; do
        [ -f "$f" ] && cp "$f" "$CURSOR_DIR/hooks/pre-commit/" && chmod +x "$CURSOR_DIR/hooks/pre-commit/$(basename "$f")" 2>/dev/null || true && echo "  + hooks/pre-commit/$(basename "$f")"
      done
    fi
    
    # Skills: completo = all; custom = by category (registry); minimo = none
    if [ "$PROFILE" = "completo" ]; then
      for skill in ux-message-flows n8n-workflows json-data-config sql-postgres prompts-markdown; do
        if [ -f "$SRC/skills/$skill/SKILL.md" ]; then
          mkdir -p "$CURSOR_DIR/skills/$skill"
          cp "$SRC/skills/$skill/SKILL.md" "$CURSOR_DIR/skills/$skill/"
          echo "  + skills/$skill/SKILL.md"
        fi
      done
    elif [ "$PROFILE" = "custom" ]; then
      REGISTRY="$AGENT_KIT/skills-registry.json"
      echo "  Skills (custom): 1) todos  2) nenhum  3) por categoria  4) por nome"
      printf "  Escolha (1-4) [1]: "
      read -r custom_choice
      custom_choice="${custom_choice:-1}"
      if [ "$custom_choice" = "2" ]; then
        echo "  (no skills installed)"
      elif [ "$custom_choice" = "3" ] && [ -f "$REGISTRY" ]; then
        echo "  Available categories: data, docs, integrations, quality, devops, creation"
        printf "  Categories (comma) or Enter=all: "
        read -r custom_cats
        if [ -z "$custom_cats" ]; then
          custom_cats="data,docs,integrations,quality,devops,creation"
        fi
        for cat in $(echo "$custom_cats" | tr ',' ' '); do
          cat=$(echo "$cat" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
          sed 's/},{"/\n},{"/g' "$REGISTRY" | grep -E "\"category\": *\"$cat\"" | while read -r line; do
            path=$(echo "$line" | sed -n 's/.*"path": *"\([^"]*\)".*/\1/p')
            if [ -n "$path" ] && [ -f "$SRC/skills/$path/SKILL.md" ]; then
              mkdir -p "$CURSOR_DIR/skills/$path"
              cp "$SRC/skills/$path/SKILL.md" "$CURSOR_DIR/skills/$path/"
              echo "  + skills/$path/SKILL.md"
            fi
          done
        done
      elif [ "$custom_choice" = "4" ] && [ -f "$REGISTRY" ]; then
        echo "  Names: comma-separated list (e.g.: n8n-workflows,json-data-config). Use 'cursor-handoff list' to see names."
        printf "  Skills: "
        read -r custom_names
        for name in $(echo "$custom_names" | tr ',' ' '); do
          name=$(echo "$name" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
          [ -z "$name" ] && continue
          path=$(sed 's/},{"/\n},{"/g' "$REGISTRY" | grep -E "\"name\": *\"$name\"" | head -1 | sed -n 's/.*"path": *"\([^"]*\)".*/\1/p')
          if [ -n "$path" ] && [ -f "$SRC/skills/$path/SKILL.md" ]; then
            mkdir -p "$CURSOR_DIR/skills/$path"
            cp "$SRC/skills/$path/SKILL.md" "$CURSOR_DIR/skills/$path/"
            echo "  + skills/$path/SKILL.md"
          else
            echo "  (skill not found or no SKILL.md: $name)"
          fi
        done
      else
        for skill in ux-message-flows n8n-workflows json-data-config sql-postgres prompts-markdown; do
          if [ -f "$SRC/skills/$skill/SKILL.md" ]; then
            mkdir -p "$CURSOR_DIR/skills/$skill"
            cp "$SRC/skills/$skill/SKILL.md" "$CURSOR_DIR/skills/$skill/"
            echo "  + skills/$skill/SKILL.md"
          fi
        done
      fi
    fi
  fi
  
  # 2.5. Copy autogit (if exists)
  if [ -d "$AGENT_KIT/autogit" ]; then
    mkdir -p "$TARGET/autogit"
    cp "$AGENT_KIT/autogit/gitupdate.md" "$TARGET/autogit/"
    echo "  + autogit/gitupdate.md"
  fi
  
  # 3. Copy cursor-handoff to root if it doesn't exist
  if [ ! -f "$TARGET/cursor-handoff" ] && [ -f "$AGENT_KIT/cursor-handoff" ]; then
    cp "$AGENT_KIT/cursor-handoff" "$TARGET/cursor-handoff"
    chmod +x "$TARGET/cursor-handoff"
    echo "  + cursor-handoff (CLI at root)"
  fi
  
  if [ -f "$TARGET/cursor-handoff" ]; then
    chmod +x "$TARGET/cursor-handoff"
  fi
  
  echo ""
  echo "Structure verified!"
  echo ""
  
  # 4. Git hooks (instruction and optional prepare-commit-msg)
  echo "Pre-commit hook (optional): to validate JSON and detect secrets before each commit:"
  echo "  cp .cursor/hooks/pre-commit/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit"
  if [ -d "$TARGET/.git" ] && [ -f "$AGENT_KIT/git-hooks/prepare-commit-msg" ]; then
    mkdir -p "$TARGET/.git/hooks"
    cp "$AGENT_KIT/git-hooks/prepare-commit-msg" "$TARGET/.git/hooks/prepare-commit-msg"
    chmod +x "$TARGET/.git/hooks/prepare-commit-msg"
    echo "  + .git/hooks/prepare-commit-msg (removes Co-authored-by Cursor from commits)"
  else
    echo "Prepare-commit-msg (optional): removes 'Co-authored-by: Cursor' from commits:"
    echo "  cp agent-kit/git-hooks/prepare-commit-msg .git/hooks/prepare-commit-msg && chmod +x .git/hooks/prepare-commit-msg"
  fi
  echo ""
  
  # 5. Onboarding or confirmation message
  if [ "${FIRST_INSTALL:-false}" = "true" ]; then
    echo "Hey! Welcome to Agent Kit."
    echo "Here you won't lose context anymore when conversations get long."
    echo ""
    echo "How it works: when context fills up, we save the state"
    echo "and you continue in a new conversation. Skills: n8n, JSON, SQL, prompts, UX."
    echo "Commands: /start-project, /handoff, /continue-plan, /context-status,"
    echo "  /summary, /git-staging, /git-prod."
    echo ""
    echo "Next step: send /start-project in Cursor chat!"
  else
    echo "Available commands:"
    echo "  /start-project    — start or resume project"
    echo "  /handoff          — save state to continue later"
    echo "  /continue-plan    — resume from where you left off"
    echo "  /context-status   — see current state"
    echo "  /summary          — quick summary"
    echo "  /git-staging      — take changes to staging"
    echo "  /git-prod         — promote staging to production"
    echo ""
    echo "CLI: ./cursor-handoff <new|status|handoff|archive|resume|list-projects|install>"
  fi
}

case "${1:-}" in
  new)     cmd_new "$2" ;;
  update)  cmd_update ;;
  status)  cmd_status ;;
  handoff) cmd_handoff "$2" ;;
  archive) cmd_archive ;;
  resume)  cmd_resume "$2" ;;
  list-projects) cmd_list_projects ;;
  list)    cmd_list_skills "$2" ;;
  install) cmd_install "$2" ;;
  help|-h|--help)
    echo "cursor-handoff - Context Memory System CLI"
    echo ""
    echo "Uso: cursor-handoff [comando] [task-id|project]"
    echo ""
    echo "Commands:"
    echo "  new [task-id]       Create new Context Pack in .cursor/context/current/"
    echo "  update             Update date in current Context Pack"
    echo "  status             Show active task, project handoffs and archived"
    echo "  handoff [project]  Generate HANDOFF in <project>/HANDOFF.md and .cursor/HANDOFF.md"
    echo "  list-projects      List folders that have HANDOFF.md"
    echo "  list [category]    List skills from registry (optional: filter by category)"
    echo "  archive            Archive current task to .cursor/context/archive/YYYY-MM/"
    echo "  resume [id]        Resume archived task or project with HANDOFF (interactive if no id)"
    echo "  install [profile]  Install Agent Kit (profile: minimo|completo|custom)"
    ;;
  *)
    echo "Usage: cursor-handoff <command> [task-id|project]"
    echo ""
    echo "Commands: new, update, status, handoff [project], list-projects, list [category], archive, resume [id], install [minimo|completo|custom]"
    echo "Use 'cursor-handoff help' to see the complete list."
    exit 2
    ;;
esac
