# Agent Kit - .gitignore

# Local handoff (do not version user state)
.cursor/HANDOFF.md

# User preferences config
.cursor/context/config.json

# Active Context Packs (are local)
.cursor/context/current/*.md
!.cursor/context/current/.gitkeep

# Local backups
.cursor/context/backups/*.md
!.cursor/context/backups/.gitkeep

# Plan shell orchestrator (scripts/plan-loop.sh) - logs and stop flag
.cursor/loop-logs/
.cursor/loop.stop

# Cursor plans (local; any subfolder, e.g. archive/)
.cursor/plans/**/*.plan.md
!.cursor/plans/.gitkeep

# MCP config (may contain tokens/keys)
.cursor/mcp.json

# IDE settings (local)
.vscode/

# Secrets e credenciais
.env
.env.*
*.pem
*.key
credentials.json

# OS files
.DS_Store
Thumbs.db

# Monorepo artifacts
node_modules/
dist/
coverage/
.turbo/
*.tsbuildinfo
