{
  "name": "agent-kit",
  "version": "4.3.0",
  "description": "Developer bootstrapper for AI-assisted IDEs — understands your project, generates tailored setup for Cursor/VS Code/Windsurf, and helps you develop without losing context.",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "git:trigger-public-sync": "bash scripts/trigger-public-sync-after-prod.sh",
    "registry:build": "node scripts/build-registry.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.9.14",
    "typescript": "^5.8.3"
  }
}
